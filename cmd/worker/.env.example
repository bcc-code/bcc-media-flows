# Temporal configuration
TEMPORAL_ADDRESS=http://temporal.lan.bcc.media
TEMPORAL_NAMESPACE=default

# Identity of the worker to be identified in temporal
IDENTITY=worker01

# How many activities to run in parallel
ACTIVITY_COUNT=5

# Rudderstack configuration
RUDDERSTACK_WRITE_KEY=
RUDDERSTACK_DATA_PLANE_URL=

# ClickUp (Shorts Export) — read-only via the public share view, no API key.
# Token is the public-share token from the view's "Share" URL.
CLICKUP_FRONTDOOR_BASE_URL=https://frontdoor-prod-eu-west-1-3.clickup.com
CLICKUP_WORKSPACE_ID=9004075864
CLICKUP_SHORTS_VIEW_ID=
CLICKUP_SHORTS_VIEW_TOKEN=